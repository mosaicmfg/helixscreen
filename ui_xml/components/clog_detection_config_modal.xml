<component>
  <!-- Styles for reactive button selection (matches filament panel pattern) -->
  <styles>
    <style name="clog_btn_selected" bg_color="#primary" bg_opa="255"/>
    <style name="clog_btn_unselected" bg_color="#primary" bg_opa="40"/>
  </styles>

  <!-- Clog Detection Configuration Modal
       Opened from grid edit mode gear icon on the clog detection widget.
       Source selection, detection mode, and danger threshold. -->
  <view name="clog_detection_config_modal"
        extends="ui_dialog" width="70%" height="content" align="center"
        flex_flow="column" style_flex_main_place="start" style_pad_gap="0">

    <!-- Header -->
    <modal_header icon_src="cog" icon_variant="accent" title="Clog Detection" title_tag="Clog Detection"/>

    <!-- Content -->
    <lv_obj width="100%" height="content"
            style_pad_left="#space_lg" style_pad_right="#space_lg"
            style_pad_top="#space_sm" style_pad_bottom="#space_lg"
            flex_flow="column" style_pad_gap="#space_md">

      <!-- Source row -->
      <lv_obj width="100%" height="content" flex_flow="column" style_pad_gap="#space_xs">
        <text_small text="Source" translation_tag="Source" style_text_color="#text_muted"/>
        <lv_obj width="100%" height="content" flex_flow="row" style_pad_gap="#space_xs">
          <ui_button name="btn_source_auto" text="Auto" flex_grow="1"
                     clickable="true">
            <bind_style name="clog_btn_selected" subject="clog_src_auto_active" ref_value="1"/>
            <bind_style name="clog_btn_unselected" subject="clog_src_auto_active" ref_value="0"/>
            <event_cb trigger="clicked" callback="on_clog_source_auto"/>
          </ui_button>
          <ui_button name="btn_source_encoder" text="Encoder" flex_grow="1"
                     clickable="true">
            <bind_style name="clog_btn_selected" subject="clog_src_encoder_active" ref_value="1"/>
            <bind_style name="clog_btn_unselected" subject="clog_src_encoder_active" ref_value="0"/>
            <event_cb trigger="clicked" callback="on_clog_source_encoder"/>
          </ui_button>
          <ui_button name="btn_source_flowguard" text="Flowguard" flex_grow="1"
                     clickable="true">
            <bind_style name="clog_btn_selected" subject="clog_src_flowguard_active" ref_value="1"/>
            <bind_style name="clog_btn_unselected" subject="clog_src_flowguard_active" ref_value="0"/>
            <event_cb trigger="clicked" callback="on_clog_source_flowguard"/>
          </ui_button>
          <ui_button name="btn_source_afc" text="AFC" flex_grow="1"
                     clickable="true">
            <bind_style name="clog_btn_selected" subject="clog_src_afc_active" ref_value="1"/>
            <bind_style name="clog_btn_unselected" subject="clog_src_afc_active" ref_value="0"/>
            <event_cb trigger="clicked" callback="on_clog_source_afc"/>
          </ui_button>
        </lv_obj>
      </lv_obj>

      <!-- Detection mode row -->
      <lv_obj width="100%" height="content" flex_flow="column" style_pad_gap="#space_xs">
        <text_small text="Detection Mode" translation_tag="Detection Mode" style_text_color="#text_muted"/>
        <lv_obj width="100%" height="content" flex_flow="row" style_pad_gap="#space_xs">
          <ui_button name="btn_mode_auto" text="Auto" flex_grow="1"
                     clickable="true">
            <bind_style name="clog_btn_selected" subject="clog_mode_auto_active" ref_value="1"/>
            <bind_style name="clog_btn_unselected" subject="clog_mode_auto_active" ref_value="0"/>
            <event_cb trigger="clicked" callback="on_clog_mode_auto"/>
          </ui_button>
          <ui_button name="btn_mode_manual" text="Manual" flex_grow="1"
                     clickable="true">
            <bind_style name="clog_btn_selected" subject="clog_mode_manual_active" ref_value="1"/>
            <bind_style name="clog_btn_unselected" subject="clog_mode_manual_active" ref_value="0"/>
            <event_cb trigger="clicked" callback="on_clog_mode_manual"/>
          </ui_button>
        </lv_obj>
      </lv_obj>

      <!-- Sliders row: Detection Length + Danger Zone side by side -->
      <lv_obj width="100%" height="content" flex_flow="row" style_pad_gap="#space_md">

        <!-- Detection length (entire section disabled in auto mode) -->
        <lv_obj name="det_length_section" width="1" flex_grow="1" height="content"
                flex_flow="column" style_pad_gap="#space_xs"
                style_opa-disabled="128">
          <bind_state_if_eq subject="clog_cfg_mode" state="disabled" ref_value="2"/>
          <lv_obj width="100%" height="content" flex_flow="row" style_flex_main_place="space_between">
            <text_small text="Detection Length" translation_tag="Detection Length" style_text_color="#text_muted"/>
            <text_small name="det_length_label" text="" bind_text="clog_cfg_det_length_text" style_text_color="#text_muted"/>
          </lv_obj>
          <lv_obj width="100%" height="content"
                  style_pad_left="#space_lg" style_pad_right="#space_lg"
                  style_pad_top="#space_xs" style_pad_bottom="#space_xs">
            <lv_slider name="det_length_slider" width="100%" min_value="2" max_value="30" value="10">
              <bind_state_if_eq subject="clog_cfg_mode" state="disabled" ref_value="2"/>
              <event_cb trigger="value_changed" callback="on_clog_det_length_changed"/>
            </lv_slider>
          </lv_obj>
          <text_tiny name="det_length_hint" text="mm before clog" translation_tag="mm before clog"
                     style_text_color="#text_muted"/>
        </lv_obj>

        <!-- Danger threshold -->
        <lv_obj width="1" flex_grow="1" height="content"
                flex_flow="column" style_pad_gap="#space_xs">
          <lv_obj width="100%" height="content" flex_flow="row" style_flex_main_place="space_between">
            <text_small text="Danger Zone" translation_tag="Danger Zone" style_text_color="#text_muted"/>
            <text_small name="threshold_label" text="" bind_text="clog_cfg_threshold_text" style_text_color="#text_muted"/>
          </lv_obj>
          <lv_obj width="100%" height="content"
                  style_pad_left="#space_lg" style_pad_right="#space_lg"
                  style_pad_top="#space_xs" style_pad_bottom="#space_xs">
            <lv_slider name="threshold_slider" width="100%" min_value="0" max_value="90" value="0">
              <event_cb trigger="value_changed" callback="on_clog_threshold_changed"/>
            </lv_slider>
          </lv_obj>
          <text_tiny text="0 = computed" translation_tag="0 = computed"
                     style_text_color="#text_muted"/>
        </lv_obj>
      </lv_obj>
    </lv_obj>

    <!-- Buttons -->
    <modal_button_row secondary_text="Cancel" secondary_callback="on_modal_cancel_clicked"
                      primary_text="Save" primary_callback="on_modal_ok_clicked"/>
  </view>
</component>
