<component>
  <view name="exclude_object_map"
        style_width="100%"
        style_height="100%"
        style_bg_color="#screen_bg"
        style_bg_opa="255"
        style_pad_all="#space_sm"
        flex_flow="column"
        scrollbar_mode="off"
        scrollable="false">

    <!-- Build plate area — object rects added as children in C++ -->
    <lv_obj name="plate_area"
            style_width="100%"
            flex_grow="1"
            style_bg_color="#card_bg"
            style_bg_opa="40"
            style_border_width="1"
            style_border_color="#border"
            style_border_opa="80"
            style_border_side="full"
            style_radius="8"
            style_pad_all="0"
            clickable="false">

      <text_tiny name="plate_dims_label"
                 style_text_color="#text_muted"
                 align="top_left"
                 style_pad_left="#space_xs"
                 style_pad_top="#space_xs"
                 clickable="false"
                 event_bubble="true"/>

      <!-- Empty state message: hidden imperatively in C++ after build_object_rects().
           Starts hidden; C++ calls lv_obj_remove_flag(HIDDEN) when no rects exist. -->
      <text_body name="empty_message"
                 text="Object positions unavailable"
                 style_text_color="#text_muted"
                 align="center"
                 hidden="true"
                 clickable="false"
                 event_bubble="true"/>

      <!-- Close button — top right of plate area (must be inside non-flex parent for align to work) -->
      <lv_obj name="close_btn"
              align="top_right"
              style_translate_x="-4"
              style_translate_y="4"
              style_width="36"
              style_height="36"
              style_bg_color="#card_bg"
              style_bg_opa="180"
              style_radius="18"
              style_border_width="0"
              style_pad_all="0">
        <event_cb trigger="clicked" callback="on_exclude_map_close"/>
        <icon src="close" size="sm" style_text_color="#text_muted"
              align="center"
              clickable="false" event_bubble="true"/>
      </lv_obj>
    </lv_obj>

    <!-- Key bar area -->
    <lv_obj name="key_bar"
            style_width="100%"
            style_height="content"
            style_max_height="48"
            style_bg_opa="0"
            style_pad_all="#space_xs"
            style_pad_top="#space_sm"
            flex_flow="row_wrap"
            style_flex_main_place="center"
            style_flex_cross_place="center"
            style_pad_row="2"
            style_pad_column="#space_sm"
            style_border_width="0"
            scrollbar_mode="off"
            scrollable="false"
            clickable="false"/>

  </view>
</component>
