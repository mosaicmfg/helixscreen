<component>
  <view name="console_panel" extends="overlay_panel" title="Console" title_tag="Console">
    <!-- Content Area -->
    <lv_obj name="overlay_content"
            width="100%" flex_grow="1" style_pad_all="#space_md" style_pad_top="0" scrollable="false" flex_flow="column"
            style_pad_gap="#space_sm">
      <!-- Disable content when printer not connected or klippy not ready -->
      <bind_state_if_not_eq subject="nav_buttons_enabled" state="disabled" ref_value="1"/>
      <!-- Status message (hidden when empty to avoid dead space) -->
      <text_small name="status_message" width="100%" text="" bind_text="console_status" style_text_align="center">
        <bind_flag_if_eq subject="console_status_visible" flag="hidden" ref_value="0"/>
      </text_small>
      <!-- Console output container (scrollable, subtle background) -->
      <lv_obj name="console_container"
              width="100%" flex_grow="1" style_bg_color="#screen_bg" style_bg_opa="255" style_radius="#border_radius"
              style_pad_all="#space_md" scrollable="true" flex_flow="column" style_pad_gap="#space_xxs">
        <!-- Console entries populated dynamically by C++ (text_small labels) -->
        <!-- Empty state (shown when no history available, inside console bg) -->
        <lv_obj name="empty_state"
                width="100%" height="100%" flex_flow="column" style_flex_main_place="center"
                style_flex_cross_place="center" style_flex_track_place="center"
                style_pad_gap="#space_md" scrollable="false">
          <bind_flag_if_eq subject="console_has_entries" flag="hidden" ref_value="1"/>
          <icon src="console" size="xl" variant="secondary"/>
          <text_heading text="No History" translation_tag="No History" width="content" style_text_align="center"/>
          <text_muted text="G-code commands will appear here" translation_tag="G-code commands will appear here" width="content" style_text_align="center"/>
        </lv_obj>
      </lv_obj>
      <!-- G-code input row -->
      <lv_obj name="input_row"
              width="100%" height="content" style_pad_all="0" flex_flow="row" style_pad_gap="#space_sm"
              style_flex_cross_place="center" scrollable="false">
        <!-- G-code text input -->
        <text_input name="gcode_input" flex_grow="1" placeholder="Enter G-code command..." placeholder_tag="Enter G-code command..." one_line="true"/>
        <!-- Send button -->
        <ui_button name="send_btn" width="60" icon="send">
          <event_cb trigger="clicked" callback="on_console_send_clicked"/>
        </ui_button>
        <!-- Clear button -->
        <ui_button name="clear_btn" width="60" height="100%" variant="secondary" icon="delete">
          <event_cb trigger="clicked" callback="on_console_clear_clicked"/>
        </ui_button>
        <!-- Settings gear: opens console_settings_overlay (filter toggles, future per-pattern editor) -->
        <ui_button name="settings_btn" width="60" height="100%" variant="secondary" icon="cog">
          <event_cb trigger="clicked" callback="on_console_settings_clicked"/>
        </ui_button>
      </lv_obj>
    </lv_obj>
  </view>
</component>
